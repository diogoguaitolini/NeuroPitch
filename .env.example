# NeuroPitch — environment variables
# Copy this file to .env and fill in your keys. Never commit .env to git.

# OpenAI — used for: Whisper (transcription), GPT (rewriting), TTS (synthesis)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# HuggingFace — used for: TRIBE V2 weights (facebook/tribev2), LLaMA 3.2-3B
# Requires accepted access for both gated models.
# Create a read token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Logging level (DEBUG | INFO | WARNING)
LOG_LEVEL=INFO
